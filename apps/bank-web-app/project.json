{
  "name": "@demo-bank-app/bank-web-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/bank-web-app/src",
  "targets": {
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "echo '🏗️  Deploying frontend infrastructure with SAM...'",
          "sam deploy --config-env {args.environment} --no-confirm-changeset --no-fail-on-empty-changeset",
          "echo '📦 Syncing frontend assets to S3...'",
          "aws s3 sync dist s3://demo-bank-app-frontend-{args.environment} --delete --region eu-west-1",
          "./scripts/invalidate-cache.sh {args.environment}",
          "echo '✅ Frontend deployment complete!'"
        ],
        "cwd": "apps/bank-web-app",
        "parallel": false
      },
      "dependsOn": ["build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "apps/bank-web-app/**/*.{ts,tsx,js,jsx}",
          "apps/bank-web-app/package.json"
        ]
      },
      "dependsOn": ["typecheck"]
    }
  }
}
