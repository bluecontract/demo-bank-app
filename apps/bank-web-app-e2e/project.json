{
  "name": "@demo-blue/bank-web-app-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/bank-web-app-e2e/src",
  "implicitDependencies": ["@demo-blue/bank-web-app"],
  "targets": {
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/bank-web-app-e2e",
        "commands": [
          "npx tsx ../../scripts/wait-for-backend.ts",
          "playwright test"
        ],
        "parallel": false
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/bank-web-app-e2e",
        "command": "eslint ."
      },
      "dependsOn": ["typecheck"]
    }
  }
}
