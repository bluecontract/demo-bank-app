{
  "name": "@demo-blue/bank-lambda",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/bank-lambda/src",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx build bank-lambda --configuration=development",
          "mv dist/apps/bank-lambda/main.cjs dist/apps/bank-lambda/main.js",
          "cd apps/bank-lambda && sam local start-api --port 3000"
        ],
        "parallel": false
      },
      "dependsOn": ["localstack:serve"]
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/bank-lambda"],
      "defaultConfiguration": "development",
      "options": {
        "commands": ["cd apps/bank-lambda && npm run build"],
        "parallel": false
      },
      "configurations": {
        "development": {
          "commands": [
            "cd apps/bank-lambda && npm run build -- --tree-shaking=false"
          ]
        },
        "production": {
          "commands": [
            "cd apps/bank-lambda && npm run build -- --tree-shaking=true --minify"
          ]
        }
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vitest run --config vitest.config.ts",
        "cwd": "apps/bank-lambda",
        "env": {
          "VITEST_EXCLUDE_INTEGRATION": "true"
        }
      },
      "dependsOn": ["^build"]
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "find src -name '*.integration.test.ts' -exec npx vitest run --config vitest.config.ts {} +"
        ],
        "cwd": "apps/bank-lambda",
        "parallel": false
      },
      "dependsOn": ["^build", "localstack:serve"]
    },
    "test:integration:ci": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "find src -name '*.integration.test.ts' -exec npx vitest run --config vitest.config.ts {} +"
        ],
        "cwd": "apps/bank-lambda",
        "parallel": false
      },
      "dependsOn": ["^build"]
    },
    "test:all": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vitest run",
        "cwd": "apps/bank-lambda"
      },
      "dependsOn": ["^build", "localstack:serve"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "apps/bank-lambda/**/*.{ts,tsx,js,jsx}",
          "apps/bank-lambda/package.json"
        ]
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "sam deploy --config-env {args.environment} --no-confirm-changeset --no-fail-on-empty-changeset"
        ],
        "cwd": "apps/bank-lambda",
        "parallel": false
      },
      "dependsOn": ["build"]
    }
  },
  "implicitDependencies": []
}
