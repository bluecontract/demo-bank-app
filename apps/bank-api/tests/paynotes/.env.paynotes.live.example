# LocalStack-backed PayNote live / serial scenarios
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

AUTH_DYNAMO_TABLE_NAME=demo-bank-paynotes-live-auth
BANKING_DYNAMO_TABLE_NAME=demo-bank-paynotes-live-banking
JWT_SECRET_ARN=/demo-bank-app/integration-test/jwt-secret
MYOS_SECRET_ARN=/demo-bank-app/integration-test/myos-credentials
