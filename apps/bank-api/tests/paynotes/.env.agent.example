# Source-of-truth values for agent / runner bootstrap.
# Copy the values you need into the repository-root .env.agent file before
# running live or E2E PayNote scenarios.

MYOS_BASE_URL=https://myos-sandbox.example/
MYOS_API_KEY=replace-me
MYOS_ACCOUNT_ID=replace-me

# Bank-side MyOS credentials used to seed the local bank secret when needed.
BANK_MYOS_ACCOUNT_ID=replace-me
BANK_MYOS_API_KEY=replace-me
