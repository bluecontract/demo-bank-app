{
  "name": "@demo-blue/bank-api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "nx": {},
  "main": "main.js",
  "scripts": {
    "build:setup": "mkdir -p ../../dist/apps/bank-api/lambda ../../dist/apps/bank-api/seed && cp template.yaml ../../dist/apps/bank-api/template.yaml",
    "build:lambda": "esbuild src/main.ts --bundle --platform=node --format=cjs --target=node22 --outfile=../../dist/apps/bank-api/lambda/main.cjs --sourcemap",
    "build:seed": "esbuild scripts/seed-funding-source.ts --bundle --platform=node --format=cjs --target=node22 --outfile=../../dist/apps/bank-api/seed/seed-funding-source.cjs --sourcemap",
    "build": "npm run build:setup && npm run build:lambda && npm run build:seed",
    "seed-funding-source": "AWS_ACCESS_KEY_ID=test AWS_SECRET_ACCESS_KEY=test AWS_REGION=eu-central-1 AWS_ENDPOINT_URL='http://localhost:4566' TABLE=demo-bank-dev npx tsx ./scripts/seed-funding-source.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.840.0",
    "@aws-sdk/client-secrets-manager": "^3.840.0",
    "@blue-labs/language": "^1.36.0",
    "@demo-blue/auth": "*",
    "@demo-blue/banking": "*",
    "@demo-blue/shared-bank-api-contract": "*",
    "@demo-blue/shared-core": "*",
    "@demo-blue/shared-observability": "*",
    "@ts-rest/core": "^3.52.1",
    "@ts-rest/serverless": "^3.52.1",
    "@types/aws-lambda": "^8.10.150",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.3.0"
  }
