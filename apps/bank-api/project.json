{
  "name": "@demo-bank-app/bank-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/bank-api/src",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx build bank-api --configuration=development",
          "cd apps/bank-api && if [ -f ../../.localstack.env ]; then set -a; . ../../.localstack.env; set +a; fi; ./scripts/deploy-localstack.sh --no-confirm-changeset --resolve-s3 --parameter-overrides AwsEndpointUrl=${LOCALSTACK_DOCKER_ENDPOINT_URL:-http://host.docker.internal:${LOCALSTACK_EDGE_PORT:-4566}}",
          "cd apps/bank-api && if [ -f ../../.localstack.env ]; then set -a; . ../../.localstack.env; set +a; fi; npm run seed-secrets",
          "cd apps/bank-api && if [ -f ../../.localstack.env ]; then set -a; . ../../.localstack.env; set +a; fi; npm run seed-funding-source",
          "cd apps/bank-api && if [ -f ../../.localstack.env ]; then set -a; . ../../.localstack.env; set +a; fi; ./scripts/start-local-api.sh"
        ],
        "parallel": false,
        "env": {
          "AWS_PROFILE": "localstack",
          "AWS_CONFIG_FILE": ".aws/config",
          "AWS_SHARED_CREDENTIALS_FILE": ".aws/credentials",
          "AWS_EC2_METADATA_DISABLED": "true",
          "AWS_REGION": "eu-west-1"
        }
      },
      "dependsOn": ["localstack:serve"]
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/bank-api"],
      "defaultConfiguration": "development",
      "dependsOn": ["^build"],
      "options": {
        "commands": ["cd apps/bank-api && npm run build"],
        "parallel": false
      },
      "configurations": {
        "development": {
          "commands": [
            "cd apps/bank-api && npm run build -- --tree-shaking=false"
          ]
        },
        "production": {
          "commands": [
            "cd apps/bank-api && npm run build -- --tree-shaking=true --minify"
          ]
        }
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vitest run --config vitest.config.ts",
        "cwd": "apps/bank-api",
        "env": {
          "VITEST_EXCLUDE_INTEGRATION": "true"
        }
      },
      "dependsOn": ["^build"]
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "find src -name '*.integration.test.ts' -exec npx vitest run --config vitest.config.ts {} +"
        ],
        "cwd": "apps/bank-api",
        "parallel": false
      },
      "dependsOn": ["^build", "localstack:serve"]
    },
    "test:integration:debug": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "find src -name '*.integration.test.ts' -exec node --inspect ../../node_modules/vitest/vitest.mjs watch --config vitest.config.ts {} +"
        ],
        "cwd": "apps/bank-api",
        "parallel": false
      },
      "dependsOn": ["^build", "localstack:serve"]
    },
    "test:integration:ci": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "find src -name '*.integration.test.ts' -exec npx vitest run --config vitest.config.ts {} +"
        ],
        "cwd": "apps/bank-api",
        "parallel": false
      },
      "dependsOn": ["^build"]
    },
    "test:all": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vitest run",
        "cwd": "apps/bank-api"
      },
      "dependsOn": ["^build", "localstack:serve"]
    },
    "test:paynotes:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vitest run --config vitest.paynotes.integration.config.ts",
        "cwd": "apps/bank-api"
      },
      "dependsOn": ["^build", "localstack:serve"]
    },
    "test:paynotes:integration:serial": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vitest run --config vitest.paynotes.integration.serial.config.ts",
        "cwd": "apps/bank-api"
      },
      "dependsOn": ["^build", "localstack:serve"]
    },
    "test:paynotes:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vitest run --config vitest.paynotes.e2e.config.ts",
        "cwd": "apps/bank-api"
      }
    },
    "test:paynotes:all": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npx vitest run --config vitest.paynotes.integration.config.ts",
          "npx vitest run --config vitest.paynotes.integration.serial.config.ts"
        ],
        "cwd": "apps/bank-api",
        "parallel": false
      },
      "dependsOn": ["^build", "localstack:serve"]
    },
    "test:debug": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node --inspect ../../node_modules/vitest/vitest.mjs watch --config vitest.config.ts",
        "cwd": "apps/bank-api",
        "env": {
          "VITEST_EXCLUDE_INTEGRATION": "true"
        }
      },
      "dependsOn": ["^build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "apps/bank-api/**/*.{ts,tsx,js,jsx}",
          "apps/bank-api/package.json"
        ]
      },
      "dependsOn": ["typecheck"]
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["./scripts/deploy-aws.sh {args.environment}"],
        "cwd": "apps/bank-api",
        "parallel": false
      },
      "dependsOn": ["build"]
    }
  },
  "implicitDependencies": []
}
