{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["development"],
    "baseUrl": ".",
    "paths": {
      "@demo-bank-app/auth": ["libs/auth/src/index.ts"],
      "@demo-bank-app/banking": ["libs/banking/src/index.ts"],
      "@demo-bank-app/shared-bank-api-client": [
        "libs/shared/bank-api-client/src/index.ts"
      ],
      "@demo-bank-app/shared-bank-api-contract": [
        "libs/shared/bank-api-contract/src/index.ts"
      ],
      "@demo-bank-app/shared-config": ["libs/shared/config/src/index.ts"],
      "@demo-bank-app/shared-core": ["libs/shared/core/src/index.ts"],
      "@demo-bank-app/shared-observability": [
        "libs/shared/observability/src/index.ts"
      ]
    }
  }
}
