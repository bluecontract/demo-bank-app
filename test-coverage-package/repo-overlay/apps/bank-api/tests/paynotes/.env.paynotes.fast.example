# LocalStack / handler-driven integration
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

AUTH_DYNAMO_TABLE_NAME=demo-bank-paynotes-fast-auth
BANKING_DYNAMO_TABLE_NAME=demo-bank-paynotes-fast-banking
JWT_SECRET_ARN=/demo-bank-app/integration-test/jwt-secret
MYOS_SECRET_ARN=/demo-bank-app/integration-test/myos-credentials
OPENAI_API_KEY_SECRET_ARN=/demo-bank-app/integration-test/openai-api-key

# Bank default if omitted: demo-bank-processor-token
CARD_PROCESSOR_TOKEN=demo-bank-processor-token
CARD_SETTLEMENT_ACCOUNT_ID=card-settlement-account-id
CARD_SETTLEMENT_ACCOUNT_NUMBER=0000000000000001
