# Enable real MyOS canaries
MYOS_E2E_ENABLED=0
PAYNOTE_E2E_RUN_ID=
PAYNOTE_E2E_EVENT_SOURCE_MODE=pull-and-post

# Read these from .env.agent or map them during test bootstrap:
# MYOS_BASE_URL, MYOS_API_KEY, MYOS_ACCOUNT_ID
MYOS_E2E_BASE_URL=https://myos-sandbox.example
MYOS_E2E_API_KEY=replace-me
MYOS_E2E_ACCOUNT_ID=replace-me

# Bank test env
BANK_E2E_BASE_URL=https://bank-test.example
# Bank default if not overridden in env: demo-bank-processor-token
BANK_E2E_CARD_PROCESSOR_TOKEN=demo-bank-processor-token

MYOS_E2E_TEST_MERCHANT_ID=replace-me
MYOS_E2E_TEST_TARGET_MERCHANT_ID=replace-me

# Placeholder only if bank boot path requires secret presence
OPENAI_API_KEY=dummy-not-used

# Fallback mode: existing webhook -> queue
PAYNOTE_E2E_WEBHOOK_QUEUE_URL=
PAYNOTE_E2E_WEBHOOK_AWS_REGION=
PAYNOTE_E2E_WEBHOOK_AWS_ACCESS_KEY_ID=
PAYNOTE_E2E_WEBHOOK_AWS_SECRET_ACCESS_KEY=
PAYNOTE_E2E_WEBHOOK_AWS_SESSION_TOKEN=
PAYNOTE_E2E_WEBHOOK_DLQ_URL=

# Only for direct-webhook fallback
MYOS_E2E_WEBHOOK_CALLBACK_URL=
MYOS_E2E_WEBHOOK_SHARED_SECRET=
MYOS_E2E_WEBHOOK_ADMIN_API_KEY=
MYOS_E2E_WEBHOOK_ID=
