{
  "name": "demo-blue",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "nx serve bank-web-app",
    "start": "nx serve bank-web-app",
    "build": "nx affected --target=build",
    "build:all": "nx run-many --target=build --all",
    "test": "nx affected --target=test",
    "test:all": "nx run-many --target=test --all",
    "test:integration": "nx affected --target=test:integration",
    "test:integration:all": "nx run-many --target=test:integration --all",
    "test:watch": "nx test bank-web-app --watch",
    "e2e": "E2E_BASE_URL=http://localhost:4200 BANK_API_URL=http://localhost:3000 nx e2e bank-web-app-e2e",
    "e2e:dev": "E2E_BASE_URL=https://d3ezdbfxa4waui.cloudfront.net BANK_API_URL=https://l68zdm1aqg.execute-api.eu-central-1.amazonaws.com/dev nx e2e bank-web-app-e2e",
    "e2e:prod": "E2E_BASE_URL=https://d1dw3eypxw8902.cloudfront.net BANK_API_URL=https://cceazxhci8.execute-api.eu-central-1.amazonaws.com/prod nx e2e bank-web-app-e2e",
    "lint": "nx affected --target=lint",
    "lint:all": "nx run-many --target=lint --all",
    "lint:fix": "nx affected --target=lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:staged": "lint-staged",
    "security:audit": "npm audit --production --audit-level=moderate",
    "security:audit:dev": "npm audit --audit-level=high",
    "security:audit:fix": "npm audit fix",
    "pre-commit": "npm run format:staged && npm run test",
    "validate-commit": "commitlint --edit",
    "clean": "nx reset",
    "graph": "nx graph",
    "serve:all": "nx run-many --target=serve --all",
    "serve:stack": "nx run-many --target=serve --projects=localstack,bank-api,bank-web-app",
    "docker:check": "docker info > /dev/null 2>&1 || (echo 'Error: Docker is not running. Please start Docker first.' && exit 1)",
    "generate-docs": "npx tsx scripts/generate-openapi.ts",
    "wait-for-backend": "npx tsx scripts/wait-for-backend.ts",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.840.0",
    "@aws-sdk/client-ssm": "^3.840.0",
    "@aws-sdk/lib-dynamodb": "^3.840.0",
    "@demo-blue/shared-bank-api-client": "*",
    "@demo-blue/shared-bank-api-contract": "*",
    "@tanstack/react-query": "^5.17.10",
    "@ts-rest/core": "^3.52.1",
    "@ts-rest/serverless": "^3.52.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-router-dom": "6.29.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.8.0",
    "@nx/devkit": "21.2.1",
    "@nx/esbuild": "^21.2.1",
    "@nx/eslint": "21.2.1",
    "@nx/eslint-plugin": "21.2.1",
    "@nx/js": "21.2.1",
    "@nx/node": "^21.2.1",
    "@nx/playwright": "21.2.1",
    "@nx/react": "21.2.1",
    "@nx/vite": "21.2.1",
    "@nx/web": "21.2.1",
    "@playwright/test": "^1.36.0",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.1.0",
    "@ts-rest/open-api": "^3.52.1",
    "@types/aws-lambda": "^8.10.150",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.6",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^3.0.5",
    "@vitest/ui": "^3.0.0",
    "autoprefixer": "10.4.13",
    "esbuild": "^0.25.5",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-playwright": "^1.6.2",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "husky": "^9.1.7",
    "jiti": "2.4.2",
    "js-yaml": "^4.1.0",
    "jsdom": "~22.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "lint-staged": "^16.1.2",
    "nx": "21.2.1",
    "postcss": "8.4.38",
    "prettier": "^2.6.2",
    "tailwindcss": "3.4.3",
    "tslib": "^2.3.0",
    "tsx": "^4.20.3",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.29.0",
    "verdaccio": "^6.0.5",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "workspaces": [
    "apps/*",
    "libs/*",
    "libs/shared/*"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,md,html,yml,yaml}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    }
  }
}
