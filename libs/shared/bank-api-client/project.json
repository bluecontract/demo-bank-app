{
  "name": "@demo-blue/shared-bank-api-client",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/shared/bank-api-client/src",
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "libs/shared/bank-api-client/dist",
        "main": "libs/shared/bank-api-client/src/index.ts",
        "tsConfig": "libs/shared/bank-api-client/tsconfig.lib.json",
        "format": ["esm"],
        "declarationRootDir": "libs/shared/bank-api-client/src"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "libs/shared/bank-api-client/**/*.{ts,tsx,js,jsx}",
          "libs/shared/bank-api-client/package.json"
        ]
      },
      "dependsOn": ["typecheck"]
    }
  },
  "implicitDependencies": []
}
