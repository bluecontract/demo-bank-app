{
  "name": "@demo-bank-app/shared-bank-api-contract",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/shared/bank-api-contract/src",
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "libs/shared/bank-api-contract/dist",
        "main": "libs/shared/bank-api-contract/src/index.ts",
        "tsConfig": "libs/shared/bank-api-contract/tsconfig.lib.json",
        "format": ["esm"],
        "declarationRootDir": "libs/shared/bank-api-contract/src"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "libs/shared/bank-api-contract/**/*.{ts,tsx,js,jsx}",
          "libs/shared/bank-api-contract/package.json"
        ]
      },
      "dependsOn": ["typecheck"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vitest run --config vitest.config.ts",
        "cwd": "libs/shared/bank-api-contract"
      }
    }
  },
  "implicitDependencies": []
}
