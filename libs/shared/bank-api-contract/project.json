{
  "name": "@demo-blue/shared-bank-api-contract",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/shared/bank-api-contract/src",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared/bank-api-contract",
        "main": "libs/shared/bank-api-contract/src/index.ts",
        "tsConfig": "libs/shared/bank-api-contract/tsconfig.lib.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "libs/shared/bank-api-contract/**/*.{ts,tsx,js,jsx}",
          "libs/shared/bank-api-contract/package.json"
        ]
      }
    }
  },
  "implicitDependencies": []
}
