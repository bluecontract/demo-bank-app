{
  "name": "@demo-bank-app/shared-bank-api-contract",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "libs/shared/bank-api-contract/dist",
          "main": "libs/shared/bank-api-contract/src/index.ts",
          "tsConfig": "libs/shared/bank-api-contract/tsconfig.lib.json",
          "format": [
            "esm"
          ],
          "declarationRootDir": "libs/shared/bank-api-contract/src"
        }
      }
    }
  },
  "dependencies": {
    "@blue-labs/language": "3.4.1",
    "@blue-repository/types": "0.9.0",
    "@ts-rest/core": "^3.52.1",
    "xss": "^1.0.15",
    "zod": "^3.25.67"
  }
}
