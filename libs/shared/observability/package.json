{
  "name": "@demo-bank-app/shared-observability",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "libs/shared/observability/dist",
          "main": "libs/shared/observability/src/index.ts",
          "tsConfig": "libs/shared/observability/tsconfig.lib.json",
          "format": [
            "esm"
          ],
          "declarationRootDir": "libs/shared/observability/src"
        }
      },
      "dependsOn": [
        "typecheck"
      ]
    }
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.0.0",
    "@aws-lambda-powertools/metrics": "^2.0.0"
  }
}
