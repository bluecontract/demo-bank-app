{
  "name": "@demo-bank-app/contracts",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/contracts/src",
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "libs/contracts/dist",
        "main": "libs/contracts/src/index.ts",
        "tsConfig": "libs/contracts/tsconfig.lib.json",
        "format": ["esm"],
        "declarationRootDir": "libs/contracts/src"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "libs/contracts/**/*.{ts,tsx,js,jsx}",
          "libs/contracts/package.json"
        ]
      },
      "dependsOn": ["typecheck"]
    }
  },
  "implicitDependencies": []
}
