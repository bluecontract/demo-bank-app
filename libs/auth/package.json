{
  "name": "@demo-bank-app/auth",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "libs/auth/dist",
          "main": "libs/auth/src/index.ts",
          "tsConfig": "libs/auth/tsconfig.lib.json",
          "format": [
            "esm"
          ],
          "declarationRootDir": "libs/auth/src"
        }
      },
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npx vitest run --config vite.config.ts --exclude **/*.integration.test.ts",
          "cwd": "libs/auth",
          "env": {
            "VITEST_EXCLUDE_INTEGRATION": "true"
          }
        },
        "dependsOn": [
          "^build"
        ]
      },
      "test:integration": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "find src -name '*.integration.test.ts' -exec npx vitest run --config vite.config.ts {} +"
          ],
          "cwd": "libs/auth",
          "parallel": false
        },
        "dependsOn": [
          "^build",
          "localstack:serve"
        ]
      },
      "test:integration:ci": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "find src -name '*.integration.test.ts' -exec npx vitest run --config vite.config.ts {} +"
          ],
          "cwd": "libs/auth",
          "parallel": false
        },
        "dependsOn": [
          "^build"
        ]
      },
      "test:integration:debug": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "find src -name '*.integration.test.ts' -exec node --inspect ../../node_modules/vitest/vitest.mjs watch --config vitest.config.ts {} +"
          ],
          "cwd": "libs/auth",
          "parallel": false
        },
        "dependsOn": [
          "^build",
          "localstack:serve"
        ]
      },
      "lint": {
        "executor": "@nx/eslint:lint",
        "outputs": [
          "{options.outputFile}"
        ],
        "options": {
          "lintFilePatterns": [
            "libs/auth/**/*.{ts,tsx,js,jsx}",
            "libs/auth/package.json"
          ]
        },
        "dependsOn": [
          "typecheck"
        ]
      }
    }
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.840.0",
    "@aws-sdk/lib-dynamodb": "^3.840.0",
    "@aws-sdk/client-secrets-manager": "^3.840.0",
    "@demo-bank-app/shared-config": "*",
    "@demo-bank-app/shared-core": "*",
    "@demo-bank-app/shared-observability": "*",
    "jsonwebtoken": "^9.0.0"
  }
}
